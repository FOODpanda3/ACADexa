<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="600.0" minWidth="900.0" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admindashboard.FXMLDocumentController">
   <left>
      <VBox prefHeight="600.0" prefWidth="220.0" style="-fx-background-color: #1d2b53;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Admin Panel" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="40.0" left="20.0" top="30.0" />
               </VBox.margin>
            </Label>
            
            <Button fx:id="btnDashboard" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#goToDashboard" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="🏠  Dashboard">
               <padding><Insets left="30.0" /></padding>
            </Button>
            
            <Button fx:id="btnstudents" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUsers" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="🏫  Manage Students">
               <padding><Insets left="30.0" /></padding>
            </Button>
            
            <Button fx:id="btnExams" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleManageExams" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="📤  Manage Exams">
               <padding><Insets left="30.0" /></padding>
            </Button>
            
            <Button fx:id="btnScores" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleScores" prefHeight="50.0" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;" text="📊  Student Scores">
               <padding><Insets left="30.0" /></padding>
            </Button>

            <Button fx:id="btnLogout" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" prefHeight="50.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-cursor: hand;" text="🚪  Logout">
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
               <padding><Insets left="30.0" /></padding>
            </Button>
         </children>
      </VBox>
   </left>
 
   <center>
      <AnchorPane fx:id="contentArea" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #f0f2f5;" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="dashboardPane" layoutX="32.0" layoutY="31.0" spacing="20.0" AnchorPane.bottomAnchor="31.0" AnchorPane.leftAnchor="32.0" AnchorPane.rightAnchor="32.0" AnchorPane.topAnchor="31.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label fx:id="label" text="School Exam Dashboard" textFill="#1d2b53">
                           <font>
                              <Font name="System Bold" size="24.0" />
                           </font>
                        </Label>
                        <Label fx:id="statusLabel" text="Track students, exams, live activity, and score performance from one place." textFill="#666666" />
                     </children>
                  </VBox>
                  
                  <HBox alignment="CENTER" fillHeight="false" spacing="24.0">
                     <children>
                        <VBox alignment="CENTER" maxHeight="200" maxWidth="220" minHeight="120.0" minWidth="180.0" prefHeight="160.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 15;">
                           <children>
                              <Label text="Total Students" textFill="#777777">
                                 <font><Font size="16.0" /></font>
                              </Label>
                              <Label fx:id="lblTotalStudents" text="0" textFill="#ff9a56">
                                 <font><Font name="System Bold" size="48.0" /></font>
                              </Label>
                           </children>
                        </VBox>
          
                        <VBox alignment="CENTER" maxHeight="200" maxWidth="220" minHeight="120.0" minWidth="180.0" prefHeight="160.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 15;">
                           <children>
                              <Label text="Uploaded Exams" textFill="#777777">
                                 <font><Font size="16.0" /></font>
                              </Label>
                              <Label fx:id="lblActiveExams" text="0" textFill="#5cb85c">
                                 <font><Font name="System Bold" size="48.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <HBox alignment="CENTER" fillHeight="false" spacing="24.0">
                     <children>
                        <VBox alignment="CENTER" maxHeight="200" maxWidth="220" minHeight="120.0" minWidth="180.0" prefHeight="160.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 15;">
                           <children>
                              <Label text="Live Sessions" textFill="#777777">
                                 <font><Font size="16.0" /></font>
                              </Label>
                              <Label fx:id="lblLiveSessions" text="0" textFill="#1d2b53">
                                 <font><Font name="System Bold" size="48.0" /></font>
                              </Label>
                           </children>
                        </VBox>

                        <VBox alignment="CENTER" maxHeight="200" maxWidth="220" minHeight="120.0" minWidth="180.0" prefHeight="160.0" prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 15;">
                           <children>
                              <Label text="Submitted Scores" textFill="#777777">
                                 <font><Font size="16.0" /></font>
                              </Label>
                              <Label fx:id="lblSubmittedScores" text="0" textFill="#8a2be2">
                                 <font><Font name="System Bold" size="48.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <BarChart fx:id="scoreChart" animated="false" legendVisible="false" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 10;" title="Average Overall Score by Section (%)" VBox.vgrow="ALWAYS">
                    <xAxis>
                      <CategoryAxis label="Class / Section" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                      <NumberAxis autoRanging="false" tickUnit="10.0" label="Average Score (%)" side="LEFT" upperBound="100.0" />
                    </yAxis>
                  </BarChart>
                  
               </children>
            </VBox>

         </children>
      </AnchorPane>
   </center>
</BorderPane>
