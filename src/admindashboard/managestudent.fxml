<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admindashboard.ManagestudentController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <Button fx:id="btnBack" mnemonicParsing="false" onAction="#goBack" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #ff9a56; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-background-radius: 5;" text="Back" />
                  <Label text="Student Records" textFill="#1d2b53">
                     <font><Font name="System Bold" size="26.0" /></font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label text="Search:" textFill="#1d2b53">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <TextField fx:id="txtSearchStudent" onKeyReleased="#handleFilter" prefHeight="35.0" prefWidth="220.0" promptText="Search name or ID" style="-fx-background-color: white; -fx-border-color: #1d2b53; -fx-border-radius: 5; -fx-background-radius: 5;" />
                  <Label text="Filter Section:" textFill="#1d2b53">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <ComboBox fx:id="cbSectionFilter" onAction="#handleFilter" prefHeight="35.0" prefWidth="200.0" promptText="All Sections" style="-fx-background-color: white; -fx-border-color: #1d2b53; -fx-border-radius: 5; -fx-background-radius: 5;" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Label text="Name:" textFill="#1d2b53">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtStudentName" prefHeight="35.0" prefWidth="220.0" promptText="Enter full name" style="-fx-background-color: white; -fx-border-color: #1d2b53; -fx-border-radius: 5; -fx-background-radius: 5;" />
                  <Label text="Section:" textFill="#1d2b53">
                     <font><Font name="System Bold" size="13.0" /></font>
                  </Label>
                  <TextField fx:id="txtStudentSection" prefHeight="35.0" prefWidth="160.0" promptText="e.g. Grade 10-A" style="-fx-background-color: white; -fx-border-color: #1d2b53; -fx-border-radius: 5; -fx-background-radius: 5;" />
                  <Button mnemonicParsing="false" onAction="#handleAddStudent" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Add Student" />
                  <Button mnemonicParsing="false" onAction="#handleDeleteStudent" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Delete" />
                  <Button mnemonicParsing="false" onAction="#handleClearStudents" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Clear All" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleGeneratePin" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #1d2b53; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Generate PIN" />
                  <Button mnemonicParsing="false" onAction="#handleGenerateMissingPins" prefHeight="35.0" prefWidth="190.0" style="-fx-background-color: #5cb85c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Generate Missing PINs" />
                  <Label text="Select one student to create a PIN, or create PINs for all students with blank PINs." textFill="#666666" wrapText="true" />
               </children>
            </HBox>

            <Separator prefWidth="200.0" />

            <TableView fx:id="studentTable" style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #cccccc;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colID" prefWidth="150.0" text="Student ID Number" />
                <TableColumn fx:id="colName" prefWidth="350.0" text="Full Name" />
                <TableColumn fx:id="colSection" prefWidth="200.0" text="Class / Section" />
                <TableColumn fx:id="colPin" prefWidth="150.0" text="Secret PIN" />
              </columns>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
