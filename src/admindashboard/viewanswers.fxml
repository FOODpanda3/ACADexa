<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="500.0" prefWidth="400.0" spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="admindashboard.ViewAnswersController">
   <children>
      <Label text="Student Exam Detail" textFill="#1d2b53">
         <font><Font name="System Bold" size="20.0" /></font>
      </Label>
      
      <GridPane hgap="10.0" vgap="5.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Student Name:" />
            <Label fx:id="lblName" text="---" GridPane.columnIndex="1">
               <font><Font name="System Bold" size="13.0" /></font></Label>
            <Label text="Section:" GridPane.rowIndex="1" />
            <Label fx:id="lblSection" text="---" GridPane.rowIndex="1" GridPane.columnIndex="1" />
         </children>
      </GridPane>

      <Separator prefWidth="200.0" />
      
      <Label text="Submitted Answers:" textFill="#666666">
         <font><Font name="System Italic" size="14.0" /></font>
      </Label>

      <ListView fx:id="answerListView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5; -fx-border-color: #cccccc;" />
      
      <Button mnemonicParsing="false" onAction="#handleClose" prefWidth="100.0" style="-fx-background-color: #1d2b53; -fx-text-fill: white;" text="Close" />
   </children>
</VBox> 